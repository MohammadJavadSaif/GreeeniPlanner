{
  "name": "greeniplanner",
  "version": "1.0.0",
  "description": "GreeniPlanner — Goal & Task Manager",
  "main": "main.js",
  "author": "Mohammad Javad",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.greeniplanner.app",
    "productName": "GreeniPlanner",
    "copyright": "Copyright © 2026 GreeniAI",
    "files": [
      "main.js",
      "app/**/*",
      "build/icon.ico"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "GreeniPlanner",
      "uninstallDisplayName": "GreeniPlanner",
      "artifactName": "GreeniPlanner-Setup-${version}.exe"
    }
  }
}
